# Minimal AgentCore wrapper — uses the published openclaw image as base
# but overrides the entrypoint to start server.py directly.
# This bypasses the complex entrypoint.sh and its potential failure modes.
FROM ffactory/openclaw:latest

# Write openclaw.json with env var substitution at build time is not possible,
# so we use a simple Python startup script that writes the config then runs server.py.
COPY agentcore_start.py /app/agentcore_start.py

# Override server.py with the fixed version (get_frozen_credentials fix)
COPY server.py /app/server.py

ENV OPENCLAW_SKIP_ONBOARDING=1
ENV OPENCLAW_SKIP_CRON=1
ENV PORT=8080

EXPOSE 8080

ENTRYPOINT ["python3", "/app/agentcore_start.py"]
