{
  "app": "python3 app.py",
  "watch": {
    "include": [
      "**"
    ],
    "exclude": [
      "README.md",
      "cdk*.json",
      "requirements*.txt",
      ".git",
      ".venv",
      "**/__pycache__",
      ".bedrock_agentcore.yaml"
    ]
  },
  "context": {
    "account": "862307432587",
    "region": "us-east-1",
    "aws_profile": "",
    "stack_prefix": "OpenClaw",
    "docker_image": "ffactory/openclaw:latest",
    "default_model_id": "us.anthropic.claude-sonnet-4-6",
